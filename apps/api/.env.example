# Copy this to .env for local development — never commit .env

# Database — assembled from Secrets Manager in production
# For local dev, set DATABASE_URL directly
DATABASE_URL=postgresql+asyncpg://metabookly_admin:password@localhost:5432/metabookly

# AWS
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=562675430068

# Secrets Manager path for DB credentials (used in production instead of DATABASE_URL)
DB_SECRET_NAME=/metabookly/database/master-credentials

# S3
ONIX_BUCKET_NAME=metabookly-onix-feeds-562675430068
ASSETS_BUCKET_NAME=metabookly-assets-562675430068

# Cognito
COGNITO_USER_POOL_ID=eu-west-2_Hb5mR6Ugo
COGNITO_CLIENT_ID=7khfisn3jq5iv9r1k27sgm5clt
COGNITO_REGION=eu-west-2

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
